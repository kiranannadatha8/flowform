# Copy to .env.local (or .env). Do not commit secrets.
# See README.md → Configuration for variable descriptions.

# PostgreSQL via Docker: npm run docker:up (see README)
DATABASE_URL="postgresql://formflow:formflow@localhost:5433/formflow?schema=public"

# Optional: live AI (builder suggestions, runtime follow-ups, soft hints)
OPENAI_API_KEY=

# Optional AI guardrails
FORMFLOW_AI_MAX_REQUESTS_PER_MINUTE=30
FORMFLOW_AI_MAX_CONTEXT_CHARS=12000

# Optional: lock /builder and internal /api/forms/* behind password + session cookie
# FORMFLOW_BUILDER_PASSWORD=
